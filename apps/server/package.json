    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "prisma": "^6.6.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
